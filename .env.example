# Copy this file to .env and adjust values

# Security — change this before deploying
API_KEY=changeme-use-a-long-random-string

# Redis
REDIS_URL=redis://redis:6379/0

# Worker concurrency (leave empty to auto-detect: nproc - 2, min 1)
WORKER_CONCURRENCY=

# Ports exposed on the host
FRONTEND_PORT=8080
FLOWER_PORT=5555

# Directory inside containers where output files are stored (mounted volume)
OUTPUT_DIR=/app/output

# Logging
# LOG_LEVEL: DEBUG | INFO | WARNING | ERROR  (default: INFO)
# LOG_FORMAT: json (default, machine-readable) | pretty (human-readable, for local dev)
LOG_LEVEL=INFO
LOG_FORMAT=json
